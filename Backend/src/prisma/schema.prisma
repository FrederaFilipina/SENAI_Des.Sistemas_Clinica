// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id Int @id @default(autoincrement())

  nome        String?
  email       String       @unique
  senha       String
  role        Role         @default(USER)
  tokens      Token[]
  prontuarios Prontuario[]

  @@map("usuario")
}

enum Role {
  ADMIN
  USER
}

model Token {
  id        Int       @id @default(autoincrement())
  token     String    @db.VarChar(255)
  type      TypeToken @default(ACCESS)
  revoked   Boolean   @default(false)
  expiresAt DateTime
  usuarioId Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("token")
}

enum TypeToken {
  ACCESS
  REFRESH
}

model Exame {
  id            Int      @id @default(autoincrement())
  nome          String
  data_exame    DateTime
  horario       String
  tipo_exame    String
  laboratorio   String
  url_documento String
  resultado     String

  paciente_id Int
  paciente    Paciente @relation(fields: [paciente_id], references: [id])

  @@map("exame")
}

model Prontuario {
  id                    Int       @id @default(autoincrement())
  descricao             String
  data                  DateTime?
  medico_responsavel_id Int
  paciente_id           Int
  paciente              Paciente  @relation(fields: [paciente_id], references: [id])
  usuario               Usuario   @relation(fields: [medico_responsavel_id], references: [id])

  @@map("prontuario")
}

model Consulta {
  id                 Int      @id @default(autoincrement())
  motivo             String
  data_consulta      DateTime
  horario            String
  descricao          String
  medicamento        String
  dosagem_precaucoes String
  paciente_id        Int
  paciente           Paciente @relation(fields: [paciente_id], references: [id])

  @@map("consulta")
}

model Paciente {
  id                 Int      @id @default(autoincrement())
  nome               String
  cpf                String   @unique
  rg                 String?
  sexo               String
  data_nascimento    DateTime
  estado_civil       String
  naturalidade       String
  telefone           String
  email              String
  contato_emergencia String?
  alergias           String
  cuidados_especiais String
  convenio           String
  numero_convenio    String
  validade_convenio  DateTime

  endereco Json

  Prontuario Prontuario[]
  Consulta   Consulta[]
  Exame      Exame[]

  @@map("paciente")
}
